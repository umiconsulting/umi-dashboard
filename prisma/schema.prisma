generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id             String   @id @default(cuid())
  slug           String   @unique          // "elgranribera", "kalalacafe"
  name           String                    // "El Gran Ribera"
  city           String?                   // "Culiacán, Sin."
  cardPrefix     String   @default("LYL")  // EGR, KAL — used in card numbers
  primaryColor   String   @default("#B5605A")
  secondaryColor String?
  logoUrl        String?
  stripImageUrl  String?                   // URL to custom strip/banner image for wallet pass
  passStyle      String   @default("default") // "default" (balance+member+stamps) or "stamps" (remaining+rewards)
  promoMessage   String?                   // Current promotion — changing this triggers wallet notification
  promoStartsAt  DateTime?                 // When the promotion becomes active
  promoEndsAt    DateTime?                 // When the promotion expires
  promoDays      String?                   // Comma-separated day numbers (0=Sun..6=Sat), null = all days
  businessHours      Json?                      // Per-day hours: {"0":[8,14],"1":[8,20],...} keys=getDay(), null=no enforcement
  timezone           String   @default("America/Mexico_City") // IANA timezone for business hours
  topupEnabled       Boolean  @default(true)   // false = hide monedero/balance features
  selfRegistration   Boolean  @default(true)
  subscriptionStatus String   @default("ACTIVE") // ACTIVE | SUSPENDED | TRIAL
  suspendedAt        DateTime?
  trialEndsAt        DateTime?
  birthdayRewardEnabled Boolean @default(false)
  birthdayRewardName    String  @default("Regalo de cumpleaños")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users           User[]
  cards           LoyaltyCard[]
  rewardConfigs   RewardConfig[]
  locations       Location[]
  giftCards       GiftCard[]
  birthdayRewards BirthdayReward[]
}

model Location {
  id        String  @id @default(cuid())
  tenantId  String
  name      String            // "Matriz", "Plaza Fiesta"
  address   String?
  latitude  Float?
  longitude Float?
  isActive  Boolean @default(true)

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  tenantId     String
  phone        String?
  email        String?
  name         String?
  birthDate    DateTime? @db.Date
  role         String   @default("CUSTOMER") // CUSTOMER | STAFF | ADMIN
  passwordHash String?
  device       String?  // e.g. "iPhone", "Samsung Galaxy S24", "Desktop"
  os           String?  // e.g. "iOS 17.4", "Android 14", "Windows 11"
  phoneVerifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  card         LoyaltyCard?
  sessions     Session[]
  staffVisits  Visit[]     @relation("StaffVisits")
  staffTransactions Transaction[] @relation("StaffTransactions")

  @@unique([tenantId, phone])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String
  tenantId  String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, tenantId])
}

// ─── Loyalty Card ─────────────────────────────────────────────────────────────

model LoyaltyCard {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String   @unique
  cardNumber      String   @unique

  // Gift card balance stored as centavos (integer) to avoid float issues
  // $150.50 MXN = 15050 centavos
  balanceCentavos Int      @default(0)

  // Lifetime stats
  totalVisits     Int      @default(0)

  // Current loyalty cycle progress (resets on reward earned)
  visitsThisCycle Int      @default(0)

  // Earned but unredeemed rewards
  pendingRewards  Int      @default(0)

  // Apple Wallet
  applePassSerial    String?  @unique
  applePassAuthToken String?

  // Google Wallet
  googlePassObjectId String?  @unique

  // QR security token (rotated on every scan to prevent replay)
  qrToken    String   @unique
  qrIssuedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  visits              Visit[]
  transactions        Transaction[]
  rewardRedemptions   RewardRedemption[]
  applePushTokens     ApplePushToken[]
  redeemedGiftCards   GiftCard[]
  birthdayRewards     BirthdayReward[]

  @@index([tenantId])
}

// ─── Visits ───────────────────────────────────────────────────────────────────

model Visit {
  id        String   @id @default(cuid())
  cardId    String
  staffId   String
  scannedAt DateTime @default(now())
  note      String?

  card      LoyaltyCard @relation(fields: [cardId], references: [id])
  staff     User        @relation("StaffVisits", fields: [staffId], references: [id])

  @@index([cardId])
  @@index([scannedAt])
  @@index([cardId, scannedAt])
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id             String   @id @default(cuid())
  cardId         String
  staffId        String?
  type           String   // TOPUP | PURCHASE | ADJUSTMENT
  amountCentavos Int      // positive = credit, negative = debit
  description    String?
  createdAt      DateTime @default(now())

  card           LoyaltyCard @relation(fields: [cardId], references: [id])
  staff          User?       @relation("StaffTransactions", fields: [staffId], references: [id])

  @@index([cardId])
  @@index([createdAt])
  @@index([staffId, type, createdAt])
  @@index([cardId, type, createdAt])
}

// ─── Reward Config ────────────────────────────────────────────────────────────

model RewardConfig {
  id                String   @id @default(cuid())
  tenantId          String
  visitsRequired    Int      @default(10)
  rewardName        String   @default("Recompensa de temporada")
  rewardDescription String?
  rewardCostCentavos Int     @default(0)
  isActive          Boolean  @default(true)
  activatedAt       DateTime @default(now())
  createdAt         DateTime @default(now())

  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  redemptions       RewardRedemption[]

  @@index([tenantId, isActive, activatedAt])
}

model RewardRedemption {
  id          String   @id @default(cuid())
  cardId      String
  configId    String
  staffId     String
  redeemedAt  DateTime @default(now())
  note        String?

  card        LoyaltyCard  @relation(fields: [cardId], references: [id])
  config      RewardConfig @relation(fields: [configId], references: [id])

  @@index([cardId])
}

// ─── Gift Cards ───────────────────────────────────────────────────────────────

model GiftCard {
  id               String    @id @default(cuid())
  tenantId         String
  code             String    @unique  // "A3F2-9C1D" — public redemption code

  amountCentavos   Int

  // Created by staff
  createdByStaffId String
  senderName       String?   // optional "De parte de: Juan"
  message          String?   // optional personal message

  // Recipient contact (for email/SMS notification)
  recipientEmail   String?
  recipientPhone   String?
  recipientName    String?

  // Redemption state
  isRedeemed       Boolean   @default(false)
  redeemedAt       DateTime?
  redeemedCardId   String?   // which LoyaltyCard redeemed it

  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redeemedCard     LoyaltyCard? @relation(fields: [redeemedCardId], references: [id])

  @@index([tenantId])
  @@index([code])
  @@index([tenantId, isRedeemed])
}

// ─── Birthday Rewards ─────────────────────────────────────────────────────────

model BirthdayReward {
  id            String    @id @default(cuid())
  tenantId      String
  loyaltyCardId String
  year          Int                        // calendar year, e.g. 2026
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime                  // last day of birthday month at 23:59:59
  redeemedAt    DateTime?
  status        String    @default("ACTIVE") // ACTIVE | REDEEMED | EXPIRED

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loyaltyCard LoyaltyCard @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)

  @@unique([loyaltyCardId, tenantId, year])
  @@index([tenantId])
  @@index([loyaltyCardId])
  @@index([expiresAt, status])
}

// ─── Apple Wallet Push ────────────────────────────────────────────────────────

model ApplePushToken {
  id          String   @id @default(cuid())
  cardId      String
  deviceToken String
  pushToken   String
  createdAt   DateTime @default(now())

  card        LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, deviceToken])
}
