# ── umi-cash database (Prisma) ────────────────────────────────────────────────
# Legacy mode: copy from apps/umi-cash/.env.
# Platform transition mode: point at the staging platform PostgreSQL database.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require&schema=umi_cash"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require&schema=umi_cash"
# UMI_DASHBOARD_SCHEMA: removed in the S4.1 cutover (2026-06-10) — the platform schema is the only path.

# ── ConversaFlow / KDS server mutations ──────────────────────────────────────
SUPABASE_URL="https://xbudknbimkgjjgohnjgp.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="SERVICE_ROLE_KEY_FOR_SERVER_ONLY"

# ── Browser auth/session config ──────────────────────────────────────────────
VITE_SUPABASE_URL="https://xbudknbimkgjjgohnjgp.supabase.co"
VITE_SUPABASE_ANON_KEY="ANON_KEY"
VITE_BUSINESS_SLUG="kalalacafe"

# ── local server port ─────────────────────────────────────────────────────────
PORT=4001

# ── deployed dashboard origin / reset links ───────────────────────────────────
# Vercel sets VERCEL_URL automatically for previews; set these explicitly when
# the production or staging domain is known.
APP_URL="https://dashboard.example.com"
DASHBOARD_ALLOWED_ORIGIN="https://dashboard.example.com"
